{
    "name": "PyPnbPartKeepr_Dev_Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "remoteUser": "dev",
    "containerUser": "dev",
    "workspaceFolder": "/home/dev/project",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/dev/project,type=bind",
    "mounts": [
        "source=${env:HOME}/.ssh,target=/home/dev/.ssh,type=bind,consistency=cached",
        "source=${env:HOME}/.gitconfig,target=/home/dev/.gitconfig,type=bind,consistency=cached",
        "source=/etc/hosts,target=/home/dev/.hosts,type=bind,consistency=cached",
        "source=${localWorkspaceFolder}/../master,target=/home/dev/master,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.vscode-pylance",
                "ms-python.black-formatter",
                "ms-python.flake8",
                "ms-python.isort",
                "batisteo.vscode-django",
                "monosans.djlint",
                "ckolkman.vscode-postgres",
                "mutantdino.resourcemonitor"
            ],
            "settings": {
                "python.pipenvPath": "/usr/bin/pipenv"
            }
        }
    },
    "postStartCommand": "/home/dev/project/.devcontainer/scripts/git-worktree-autofix.sh",
    "postCreateCommand": "/home/dev/project/.devcontainer/scripts/setup.sh"
}
